# ============================================================
#  使用说明
#  - 复制本文件为 .env：cp .env.example .env
#  - 本地启动：spring-dotenv 会自动读取项目根目录 .env，无需额外操作
#  - Docker：docker-compose 自动加载本目录 .env
# ============================================================


# ====================== 1. docker-compose 专用 ======================
# 这些只在 Docker Compose 中使用，本地启动可忽略

# 数据库容器（docker-compose 启动 PostgreSQL 时使用）
# 注意：业务库名固定为 openagent（由 openagent.sql 创建），无需在此配置 POSTGRES_DB
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# 前端宿主机端口（云服务器记得在安全组放通）
FRONTEND_PORT=80

# 前端构建时的 API 基址。留空走同源 + nginx 反代，最省心
# 若前后端不同域名可填：https://api.your-domain.com
VITE_API_BASE_URL=

# 后端 JVM 调参
JAVA_OPTS=-Xms512m -Xmx1024m -XX:+UseG1GC -Dfile.encoding=UTF-8


# ====================== 2. Spring 配置（本地 + Docker 共用）======================

# ---------- PostgreSQL ----------
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/openagent?stringtype=unspecified
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=

# ---------- Redis ----------
SPRING_DATA_REDIS_HOST=127.0.0.1
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_DATABASE=2

# ---------- 邮件（找回密码 / 通知用，未启用可不填）----------
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=

# ---------- 文档持久化目录 ----------
DOCUMENT_STORAGE_BASE_PATH=./data/documents

# ====================== 3. 第三方 API Key ======================

# 阿里云百炼
DASHSCOPE_EMBEDDING_MODEL_API_KEY=sk-
DASHSCOPE_EMBEDDING_MODEL_NAME=text-embedding-v3
DASHSCOPE_EMBEDDING_MODEL_DIMENSIONS=1024

DASHSCOPE_QWEN_IMAGE_MODEL_NAME=qwen-image-2.0-pro
DASHSCOPE_QWEN_IMAGE_MODEL_API_KEY=sk-

DASHSCOPE_WANX_IMAGE_MODEL_NAME=wan2.7-image-pro
DASHSCOPE_WANX_IMAGE_MODEL_API_KEY=sk-

# Tavily 联网搜索
TAVILY_API_KEY=
TAVILY_URL=https://api.tavily.com/search
TAVILY_EXTRACT_URL=https://api.tavily.com/extract

# 阿里云 OSS（文件 / 图片存储）
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_BUCKET=
OSS_URL=oss-cn-beijing.aliyuncs.com
