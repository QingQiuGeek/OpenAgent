# 模板：复制为 application-local.yaml 并填入真实凭据
# 该文件已加入 .gitignore，请勿在 application-local.yaml 中提交真实密钥

spring:
  datasource:
    username: postgres
    password: your-db-password
  mail:
    username: your-mail@qq.com
    password: your-smtp-auth-code

langchain4j:
  community:
    dashscope:
      embedding-model:
        api-key: sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 阿里云百炼 DashScope API Key，供 QwenGenImageTool（通义万相文生图）使用
# 申请：https://bailian.console.aliyun.com/?tab=model#/api-key
dashscope:
  api-key: sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
